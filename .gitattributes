# Ensure consistent line endings
*.php text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Windows specific - CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Linux/Unix specific - LF
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.fish text eol=lf

# Merge strategies for specific files
composer.json merge=union
composer.lock merge=union
package.json merge=union
package-lock.json merge=union

# Linguist overrides (for GitHub language detection)
*.blade.php linguist-language=HTML
*.twig linguist-language=HTML
*.latte linguist-language=HTML
*.hbs linguist-language=HTML
*.mustache linguist-language=HTML
*.handlebars linguist-language=HTML