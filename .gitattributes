# ============================================
# COURIER MANAGEMENT SYSTEM - GITATTRIBUTES
# ============================================

# Auto detect text files and perform LF normalization
* text=auto

# PHP
*.php text diff=php

# JavaScript
*.js text
*.jsx text
*.mjs text

# CSS
*.css text
*.scss text
*.sass text
*.less text

# HTML
*.html text
*.htm text
*.xhtml text

# Markdown
*.md text
*.markdown text

# JSON
*.json text
*.json5 text
*.jsonld text

# YAML
*.yml text
*.yaml text

# XML
*.xml text
*.xsl text
*.xslt text

# Configuration
*.conf text
*.cfg text
*.ini text
*.env text
*.dist text

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf

# Batch files
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Docker
Dockerfile text
*.dockerfile text

# Git
.gitattributes text
.gitignore text
.gitmodules text

