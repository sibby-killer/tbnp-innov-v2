/logs/security.log
/logs/auth.log
/logs/suspicious.log
/logs/alerts.log
/logs/debug.log
/logs/query.log
/logs/slow.log

# Application logs
/storage/logs/*
!/storage/logs/.gitkeep
/storage/logs/*.log
/storage/logs/*.log.*

# Framework logs
/laravel.log
/storage/logs/laravel.log
/var/log/*
!/var/log/.gitkeep

